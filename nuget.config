<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-lokale NuGet-Konfiguration für TeamsMentionNotificationCenter.
  <clear/> blendet geerbte (private/authentifizierte) Feeds NUR für dieses Repo aus,
  damit der Restore nicht an 401-geschützten Firmen-Feeds scheitert.
  Alle Abhängigkeiten dieses Projekts sind öffentlich auf nuget.org verfügbar.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
